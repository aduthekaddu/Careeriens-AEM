<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Weather"
    sling:resourceType="cq/gui/components/authoring/dialog">
    
    <content jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">

            <cityName
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                fieldLabel="City Name"
                fieldDescription="Display name shown in the widget — e.g. Mumbai"
                name="./cityName"/>

            <location
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                fieldLabel="Location (lat,lon)"
                fieldDescription="e.g. 19.0760,72.8777 for Mumbai"
                name="./location"/>

            <refreshInterval
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                fieldLabel="Refresh Interval (seconds)"
                fieldDescription="Minimum 10 seconds. Default 30."
                name="./refreshInterval"
                value="30"
                min="10"/>

        </items>
    </content>
</jcr:root>