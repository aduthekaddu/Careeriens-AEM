<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Hero"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">

                    <!-- ══ TAB 1: IMAGES (slideshow) ══ -->
                    <imagesTab jcr:primaryType="nt:unstructured"
                        jcr:title="🖼 Images"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <heroImages
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                fieldLabel="Background Images"
                                fieldDescription="Add 2+ images for slideshow. Single image = static background."
                                composite="{Boolean}true">
                                <field jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    granite:class="foundation-layout-panel"
                                    name="./heroImages">
                                    <items jcr:primaryType="nt:unstructured">
                                        <imageRef
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                            fieldLabel="Image"
                                            name="./imageRef"
                                            rootPath="/content/dam"
                                            required="{Boolean}true" />
                                    </items>
                                </field>
                            </heroImages>
                        </items>
                    </imagesTab>

                    <!-- ══ TAB 2: CONTENT ══ -->
                    <content jcr:primaryType="nt:unstructured"
                        jcr:title="📝 Content"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <badgeText
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Badge Text"
                                name="./badgeText" />
                            <headingPart1
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Heading Line 1 (white)"
                                name="./headingPart1" />
                            <headingPart2
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Heading Line 2 (orange)"
                                name="./headingPart2" />
                            <subtext
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                fieldLabel="Sub-text"
                                name="./subtext" />
                        </items>
                    </content>

                    <!-- ══ TAB 3: CTA ══ -->
                    <cta jcr:primaryType="nt:unstructured"
                        jcr:title="🔘 CTA Buttons"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <primaryCtaText
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Primary Button Text"
                                name="./primaryCtaText"
                                value="Explore Degrees" />
                            <primaryCtaLink
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Primary Button Link"
                                name="./primaryCtaLink"
                                rootPath="/content" />
                            <secondaryCtaText
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Secondary Button Text"
                                name="./secondaryCtaText"
                                value="Talk to Counselor" />
                            <secondaryCtaLink
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Secondary Button Link"
                                name="./secondaryCtaLink"
                                rootPath="/content" />
                        </items>
                    </cta>

                    <!-- ══ TAB 4: STATS ══ -->
                    <statsTab jcr:primaryType="nt:unstructured"
                        jcr:title="📊 Stats"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <stats
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                fieldLabel="Stat Boxes"
                                fieldDescription="Add up to 4 stat boxes. Upload icon as PNG/SVG to DAM first."
                                composite="{Boolean}true">
                                <field jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    granite:class="foundation-layout-panel"
                                    name="./stats">
                                    <items jcr:primaryType="nt:unstructured">
                                        <statIconRef
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                            fieldLabel="Icon (PNG or SVG from DAM)"
                                            fieldDescription="e.g. /content/dam/careeriens/icons/users.svg"
                                            name="./statIconRef"
                                            rootPath="/content/dam" />
                                        <statValue
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                            fieldLabel="Value"
                                            fieldDescription="e.g. 1500+ or Top 10+"
                                            name="./statValue"
                                            required="{Boolean}true" />
                                        <statLabel
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                            fieldLabel="Label"
                                            fieldDescription="e.g. Happy Customers"
                                            name="./statLabel"
                                            required="{Boolean}true" />
                                    </items>
                                </field>
                            </stats>
                        </items>
                    </statsTab>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>