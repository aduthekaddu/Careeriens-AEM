<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Program Hero"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">

                    <contentTab jcr:primaryType="nt:unstructured"
                        jcr:title="📝 Content"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <backLinkText
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Back Link Text"
                                fieldDescription="e.g. Back to Programs"
                                name="./backLinkText"
                                value="Back to Programs"/>
                            <backLinkHref
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Back Link URL"
                                name="./backLinkHref"
                                rootPath="/content"/>
                            <categoryBadge
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Category Badge"
                                fieldDescription="e.g. DESIGN"
                                name="./categoryBadge"/>
                            <title
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Hero Title"
                                name="./title"
                                required="{Boolean}true"/>
                            <features
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                fieldLabel="Feature Checklist"
                                fieldDescription="Two columns auto-layout"
                                composite="{Boolean}true">
                                <field jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    granite:class="foundation-layout-panel"
                                    name="./features">
                                    <items jcr:primaryType="nt:unstructured">
                                        <featureText
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                            fieldLabel="Feature"
                                            fieldDescription="e.g. Portfolio Development"
                                            name="./featureText"
                                            required="{Boolean}true"/>
                                    </items>
                                </field>
                            </features>
                        </items>
                    </contentTab>

                    <ctaTab jcr:primaryType="nt:unstructured"
                        jcr:title="🔗 CTAs"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <primaryCtaText
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Primary CTA Text"
                                name="./primaryCtaText"
                                value="Enroll Now"/>
                            <primaryCtaLink
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Primary CTA Link"
                                name="./primaryCtaLink"
                                rootPath="/content"/>
                            <secondaryCtaText
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Secondary CTA Text"
                                name="./secondaryCtaText"
                                value="Enquire Now"/>
                            <secondaryCtaLink
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Secondary CTA Link"
                                name="./secondaryCtaLink"
                                rootPath="/content"/>
                        </items>
                    </ctaTab>

                    <mediaTab jcr:primaryType="nt:unstructured"
                        jcr:title="🎨 Media &amp; Style"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <heroImageRef
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Hero Image (DAM)"
                                name="./heroImageRef"
                                rootPath="/content/dam"/>
                            <accreditedLabel
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Accredited Badge Label"
                                fieldDescription="Leave blank to hide the badge"
                                name="./accreditedLabel"
                                value="Accredited"/>
                            <accreditedIconRef
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Accredited Icon (DAM)"
                                fieldDescription="SVG or PNG for the accredited badge"
                                name="./accreditedIconRef"
                                rootPath="/content/dam"/>
                            <bgColor
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/colorfield"
                                fieldLabel="Background Color"
                                fieldDescription="Default dark green #1e3d2a"
                                name="./bgColor"
                                value="#1e3d2a"/>
                        </items>
                    </mediaTab>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>